# ============================================================
# Materials AI Platform — 环境变量配置模板
# 复制此文件为 .env 并修改
# ============================================================

# ---- 应用 ----
APP_NAME="Materials AI Platform"
APP_VERSION="2.0.0"
ENVIRONMENT=production

# ---- JWT 密钥 (生产环境务必修改!) ----
SECRET_KEY=change-this-to-a-secure-random-string

# ---- 数据库 ----
MONGODB_URI=mongodb://mongo:27017
MONGODB_DB=materials_ai
REDIS_URL=redis://redis:6379/0

# ---- AI 微服务 ----
SCIBERT_NER_URL=http://scibert-ner:8001/predict
RAG_API_URL=http://rag-api:8002
CGCNN_PROXY_URL=http://cgcnn-proxy:8003/predict
YOLO_GRAIN_URL=http://yolo-grain:8004/predict
UNET_PHASE_URL=http://unet-phase:8005/predict
CRYSTAL_DIFFUSION_URL=http://crystal-diffusion:8006/generate
EMBEDDING_API_URL=http://embedding-api:8007

# ---- OpenAI (可选 — 用于LLM增强) ----
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ---- Neo4j (可选 — 知识图谱) ----
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j123

# ---- 模型路径 ----
SCIBERT_MODEL=allenai/scibert_scivocab_uncased
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ---- 文件上传 ----
MAX_UPLOAD_SIZE_MB=500
